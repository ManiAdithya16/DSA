class Solution {

    public int countWays(String s) {

        char[] exp = s.toCharArray();
        int n = exp.length;

        int[][][] dp = new int[n][n][2];

        // base case
        for (int i = 0; i < n; i++) {
            if (exp[i] == 'T') {
                dp[i][i][1] = 1;
                dp[i][i][0] = 0;
            } else {
                dp[i][i][1] = 0;
                dp[i][i][0] = 1;
            }
        }

        for (int i = n - 1; i >= 0; i--) {
            for (int j = i + 1; j < n; j++) {

                for (int isTrue = 0; isTrue <= 1; isTrue++) {

                    int ways = 0;

                    for (int ind = i + 1; ind <= j - 1; ind += 2) {

                        int lt = dp[i][ind - 1][1];
                        int lf = dp[i][ind - 1][0];
                        int rt = dp[ind + 1][j][1];
                        int rf = dp[ind + 1][j][0];

                        char op = exp[ind];

                        if (op == '&') {
                            if (isTrue == 1)
                                ways += lt * rt;
                            else
                                ways += lt * rf + lf * rt + lf * rf;
                        }
                        else if (op == '|') {
                            if (isTrue == 1)
                                ways += lt * rt + lt * rf + lf * rt;
                            else
                                ways += lf * rf;
                        }
                        else {
                            if (isTrue == 1)
                                ways += lt * rf + lf * rt;
                            else
                                ways += lt * rt + lf * rf;
                        }
                    }

                    dp[i][j][isTrue] = ways;
                }
            }
        }

        return dp[0][n - 1][1];
    }
}
