class Solution {

    public int countSubsets(int[] arr, int k){

        int n = arr.length;

        int[][] dp = new int[n][k+1];

        if(arr[0] == 0)
            dp[0][0] = 2;
        else
            dp[0][0] = 1;

        if(arr[0] != 0 && arr[0] <= k)
            dp[0][arr[0]] = 1;

        for(int i=1;i<n;i++){

            for(int t=0;t<=k;t++){

                int notTake = dp[i-1][t];

                int take = 0;

                if(arr[i] <= t)
                    take = dp[i-1][t-arr[i]];

                dp[i][t] = take + notTake;
            }
        }

        return dp[n-1][k];
    }
}
