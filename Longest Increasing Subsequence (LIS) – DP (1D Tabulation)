public class Solution {

    public static int longestIncreasingSubsequence(int[] arr) {

        int n = arr.length;

        int[] dp = new int[n];   // dp[i] = LIS ending at index i

        // initialize all dp values as 1
        for(int i = 0; i < n; i++){
            dp[i] = 1;
        }

        int maxi = 1;   // store maximum LIS length

        for(int i = 0; i < n; i++){

            for(int prev = 0; prev < i; prev++){

                // check if we can extend the subsequence
                if(arr[prev] < arr[i]){

                    dp[i] = Math.max(dp[i], 1 + dp[prev]);
                }
            }

            // update overall LIS length
            maxi = Math.max(maxi, dp[i]);
        }

        return maxi;
    }
}
