class Solution {
    public int countPartitions(int[] arr, int d) {
        int n = arr.length;
        int totsum = 0;
        for(int x: arr){
            totsum += x;
        }
        if(totsum-d < 0 || (totsum-d) % 2 != 0) return 0;
        int target = (totsum -d)/2;
        
        int dp[][] = new int[n][target +1];
        
        if(arr[0] == 0){
            dp[0][0] = 2;
        }else{
            dp[0][0] = 1;
        }
        
        if(arr[0] != 0 && arr[0] <= target){
            dp[0][arr[0]] = 1;
        }
        
        for(int i =1;i<n;i++){
            for(int t =0;t<=target;t++){
                int nottaken = dp[i-1][t];
                
                int take = 0;
                if(arr[i] <= t){
                    take = dp[i-1][t-arr[i]];
                }
                    
                dp[i][t] = take + nottaken;
                }
                
            }
            return dp[n-1][target];
            
        }
        
    }
