import java.util.*;

class Pair {
    int row;
    int col;
    int tm;

    Pair(int _row, int _col, int _tm) {
        this.row = _row;
        this.col = _col;
        this.tm = _tm;
    }
}

class Solution {
    public int orangesRotting(int[][] grid) {

        int n = grid.length;
        int m = grid[0].length;

        Queue<Pair> q = new LinkedList<>();

        int[][] vis = new int[n][m];
        int cntFresh = 0;

        // Step 1: Traverse grid
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {

                // If rotten orange → add to queue
                if (grid[i][j] == 2) {
                    q.add(new Pair(i, j, 0));
                    vis[i][j] = 2;
                } else {
                    vis[i][j] = 0;
                }

                // Count fresh oranges
                if (grid[i][j] == 1) {
                    cntFresh++;
                }
            }
        }

        int tm = 0;
        int[] drow = {-1, 0, 1, 0};
        int[] dcol = {0, 1, 0, -1};

        int cnt = 0;

        // Step 2: BFS
        while (!q.isEmpty()) {

            int r = q.peek().row;
            int c = q.peek().col;
            int t = q.peek().tm;
            q.remove();

            tm = Math.max(tm, t);

            // Check all 4 directions
            for (int i = 0; i < 4; i++) {
                int nrow = r + drow[i];
                int ncol = c + dcol[i];

                // Valid + fresh + not visited
                if (nrow >= 0 && nrow < n && ncol >= 0 && ncol < m
                        && vis[nrow][ncol] == 0 && grid[nrow][ncol] == 1) {

                    q.add(new Pair(nrow, ncol, t + 1));
                    vis[nrow][ncol] = 2;
                    cnt++;
                }
            }
        }

        // If some fresh oranges left
        if (cnt != cntFresh) return -1;

        return tm;
    }
}
