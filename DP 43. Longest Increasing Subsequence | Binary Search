import java.util.*;

class Solution {

    public int lengthOfLIS(int[] nums) {

        ArrayList<Integer> temp = new ArrayList<>();

        temp.add(nums[0]);

        for(int i = 1; i < nums.length; i++){

            if(nums[i] > temp.get(temp.size()-1)){
                temp.add(nums[i]);
            }
            else{
                int ind = lowerBound(temp, nums[i]);
                temp.set(ind, nums[i]);
            }
        }

        return temp.size();
    }

    public int lowerBound(ArrayList<Integer> arr, int target){

        int low = 0;
        int high = arr.size()-1;
        int ans = arr.size();

        while(low <= high){

            int mid = (low+high)/2;

            if(arr.get(mid) >= target){
                ans = mid;
                high = mid-1;
            }
            else{
                low = mid+1;
            }
        }

        return ans;
    }
}
