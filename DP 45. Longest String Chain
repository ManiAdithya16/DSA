class Solution {

        public boolean comp(String s1, String s2){
            if(s1.length() +1 != s2.length()) return false;
            int i=0;
            int j=0;
            while(j<s2.length()){
                if(i<s1.length() && s1.charAt(i) == s2.charAt(j)){
                    i++;
                    j++;
                }else{
                    j++;
                }
            }
            return i == s1.length();
        }
        
        public int longestStrChain(String[] arr) {
        
        Arrays.sort(arr, (a,b) -> a.length() - b.length());
        int n = arr.length;
        int[] dp = new int[n];

        for(int i=0;i<n;i++){
            dp[i] = 1;
        }
        int maxi = 1;
        for(int i =0;i<n;i++){
            for(int prev =0;prev<i;prev++){
                if(comp(arr[prev],arr[i]) && dp[prev] +1 > dp[i]){
                    dp[i] = dp[prev] +1;
                }
            }
            if(dp[i] > maxi){
                maxi = dp[i];
            }
        }
        return maxi;

    }
}
