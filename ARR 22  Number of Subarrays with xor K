class Solution {
    public long subarrayXor(int arr[], int k) {
        int n = arr.length;
        HashMap<Integer, Integer> map = new HashMap<>();
        int xr =0;
        int cnt =0;
        map.put(0,1);
        for(int i=0;i<n;i++){
            xr ^= arr[i];
            if(map.containsKey(xr^k)){
                cnt += map.get(xr^k);
            }
            map.put(xr, map.getOrDefault(xr, 0) +1);
        }
        return cnt;
    }
}
