import java.util.*;

class Solution {

    // lower bound function
    public int lowerBound(ArrayList<Integer> list, int x){

        int low = 0;
        int high = list.size() - 1;
        int ans = list.size();

        while(low <= high){

            int mid = (low + high) / 2;

            if(list.get(mid) >= x){
                ans = mid;
                high = mid - 1;
            }
            else{
                low = mid + 1;
            }
        }

        return ans;
    }

    public int lengthOfLIS(int[] nums) {

        ArrayList<Integer> temp = new ArrayList<>();

        temp.add(nums[0]);

        for(int i = 1; i < nums.length; i++){

            if(nums[i] > temp.get(temp.size() - 1)){
                temp.add(nums[i]);
            }
            else{

                int ind = lowerBound(temp, nums[i]);

                temp.set(ind, nums[i]);
            }
        }

        return temp.size();
    }
}
